# Минимальный test-профиль для CI и локальных smoke-стендов

K8S_BOX_CLUSTER_PROFILE=test
K8S_BOX_DEPLOYMENT_ENV=test

K8S_BOX_CLUSTER_NAME=test-cluster
K8S_BOX_CLUSTER_VERSION=1.33
K8S_BOX_RELEASE_CHANNEL=STABLE
K8S_BOX_CNI_TYPE=calico

K8S_BOX_ALLOW_PUBLIC_LOAD_BALANCERS=false
K8S_BOX_MASTER_PUBLIC_ACCESS=true
K8S_BOX_ENABLE_NLB_HC_RULE=false

K8S_BOX_NODE_CORES=2
K8S_BOX_NODE_MEMORY_GB=4
K8S_BOX_NODE_BOOT_DISK_GB=30
K8S_BOX_WORKER_MIN=1
K8S_BOX_WORKER_MAX=1
K8S_BOX_WORKER_INITIAL=1

K8S_BOX_MONITORING_ENABLED=false

K8S_BOX_VAULT_PROFILE=test
K8S_BOX_VAULT_ENABLE_BACKUP_MANIFESTS=true
K8S_BOX_VAULT_ENABLE_BACKUP_MANIFESTS_IN_TEST=false

K8S_BOX_OBSERVABILITY_STACK=vm-loki-grafana
K8S_BOX_OBSERVABILITY_PROFILE=test
K8S_BOX_OBSERVABILITY_SECRET_PROVIDER=vso
K8S_BOX_OBSERVABILITY_ENABLE_SECRET_SYNC_IN_TEST=false
