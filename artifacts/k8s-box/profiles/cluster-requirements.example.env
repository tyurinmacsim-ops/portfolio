# Пример входных требований для генерации отдельного stack/state.
# Использование:
#   cp ./profiles/cluster-requirements.example.env ./profiles/<company>-<env>.env
#   vim ./profiles/<company>-<env>.env
#   ./scripts/scaffold-stack-from-requirements.sh --requirements ./profiles/<company>-<env>.env --output ../k8s-box-<company>-<env>

# --- Обязательные параметры стека ---
STACK_NAME=acme-prod
CLOUD_ID=b1gxxxxxxxxxxxxxxxxx
FOLDER_NAME=acme-prod
NETWORK_NAME=acme-vpc-01
CLUSTER_NAME=acme-prod-cluster
YC_ZONE=ru-central1-a
SUBNET_CIDR=10.42.1.0/24

# --- Базовые входные требования по нагрузке ---
# Сколько приложенческих pod планируется одновременно в кластере.
ESTIMATED_APP_PODS=120
# Средняя CPU заявка (requests.cpu) одного pod, millicores.
AVG_POD_CPU_M=120
# Средняя Memory заявка (requests.memory) одного pod, MiB.
AVG_POD_MEM_MIB=256

# --- Git/ArgoCD (обязательные, без секретов) ---
K8S_BOX_GITLAB_API_URL=https://gitlab.example.com/api/v4
K8S_BOX_GITLAB_GROUP_PATH=platform
K8S_BOX_GITLAB_SUBGROUP=infrastructure
K8S_BOX_STATIC_GIT_REPO_BASE_URL=https://gitlab.example.com/platform/infrastructure
K8S_BOX_GITLAB_REPO_USER=gitops-readonly

# --- Вариативность observability стека ---
# vm-loki-grafana | prom-loki-grafana
OBSERVABILITY_STACK=vm-loki-grafana
# profile, который будет установлен в infrastructure/observability/values.yaml
# test | dev | prod
OBSERVABILITY_PROFILE=prod
# Доставка Telegram-секрета для Alertmanager:
# vso | external-secrets | manual
OBSERVABILITY_SECRET_PROVIDER=vso
# В test обычно false, чтобы test-стек не уходил в degraded до настройки backend.
OBSERVABILITY_ENABLE_SECRET_SYNC_IN_TEST=false

# --- Вариативность Vault runtime ---
# test | prod
VAULT_PROFILE=prod
# Включать ли backup manifests в Argo Application Vault
VAULT_ENABLE_BACKUP_MANIFESTS=true
# В test обычно false, чтобы не тянуть backup-логику в облегченный профиль
VAULT_ENABLE_BACKUP_MANIFESTS_IN_TEST=false

# --- Необязательные параметры расчета/кластера (с дефолтами) ---
CLUSTER_VERSION=1.33
PUBLIC_ACCESS=true
ENVIRONMENT=prod
# release channel для control plane
RELEASE_CHANNEL=STABLE
# CNI для кластера: calico|cilium
CNI_TYPE=calico
# Разрешать ли кластеру создавать публичные LoadBalancer-сервисы.
# Для test рекомендуется false, для prod обычно true.
ALLOW_PUBLIC_LOAD_BALANCERS=true
# Явный флаг публичности master endpoint (если не задан, берется из PUBLIC_ACCESS)
MASTER_PUBLIC_ACCESS=true
# Авто-обновление control plane
MASTER_AUTO_UPGRADE=false

# Резерв на системные/служебные pod в процентах.
SYSTEM_RESERVE_PCT=30
# Целевая загрузка ноды по CPU/Memory (для расчета стартового размера).
CPU_UTIL_TARGET_PCT=70
MEM_UTIL_TARGET_PCT=75

# Тип worker-нод для расчета (vCPU, RAM GiB, диск GiB).
NODE_VCPU=4
NODE_MEMORY_GIB=16
NODE_BOOT_DISK_GB=64

# Границы autoscaling main worker-группы.
WORKER_MIN=2
WORKER_MAX=12

# Выделенная группа под monitoring (рекомендуется true для prod).
ENABLE_MONITORING_NODE=true
MONITORING_MIN=1
MONITORING_MAX=2
MONITORING_INITIAL=1

# Security / доступы
API_ALLOWED_CIDRS=0.0.0.0/0
SSH_ALLOWED_CIDRS=10.42.1.0/24
ENABLE_NLB_HC_RULE=true
ENABLE_NODEPORT_RULE=true
NODEPORT_FROM=30000
NODEPORT_TO=32767
NODEPORT_ALLOWED_CIDRS=0.0.0.0/0

# Vault infra
KMS_KEY_ROTATION_PERIOD=2160h
CREATE_BACKUP_BUCKET=true
BACKUP_BUCKET_NAME=acme-vault-backup-prod
